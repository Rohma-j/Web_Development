body{
    height: 100dvh;
    width: 100dvw;
}
#main{
        position: absolute;
    z-index: 0;
    height: 100dvh;
    width: 100dvw;
    background-image:url(pexels-clickerhappy-240040.jpg) ;
    background-size: cover;
    background-repeat: no-repeat;
}
#result{
    position:absolute;
    height: 100dvh;
    width: 100dvw;
    background-image:url(pexels-clickerhappy-240040.jpg) ;
    background-size: cover;
    background-repeat: no-repeat;
    z-index: -2;
  opacity: 0;
    /* animation: fadein 2s ease-in forwards; */
    display: flex;
    flex-wrap: wrap;
   align-content: center;
   justify-content: center;
     font-family: 'Courier New', Courier, monospace;
    font-style: italic;
    font-weight: bolder;
    font-size: 30px;
    color: white;
}
@keyframes fadein{
    0%,100%{
        opacity: 0;
    }
    25%,55%{
        opacity: 1;
    }
}
#game{
   display: flex;
   overflow: hidden;
   height:50% ; 
   width: 100%;
   flex-wrap: wrap;
   align-content: center;
   justify-content: center;
}
.circle{
    display: flex;
    flex-wrap: wrap;
    align-content: center;
   justify-content: center;
    width: 18%;
    height: 50%;
    background-color: rgb(0, 0, 0,0.3);
    border-radius: 50%;
    margin: 15px;
    font-family: 'Courier New', Courier, monospace;
    font-style: italic;
    font-weight: bolder;
    font-size: 30px;
    color: white;
    transition: background-color 0.1s ease;
}
.circle:hover{
    background-color: rgb(0, 0, 0,0.7);
}
@media (max-width: 890px) { 
    #game{
          flex-direction:column;
          height:70% ; 
    }
    .circle{
        width: 35%;
    height: 30%;
    margin: 9px;
    }
}
#message{
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-content: center;
    flex-direction: column;
    font-family: 'Courier New', Courier, monospace;
    font-style: italic;
    font-weight: bolder;
    font-size: 30px;
    color: white;
}
#win,#lose,#draw{
     align-self: center;
}
#acknowleg{
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-content: center;
    flex-direction: column;
    color:white ;
    font-family: 'Courier New', Courier, monospace;
    font-style: italic;
    font-weight: bolder;
    font-size: 20px;
    padding: 20px;
    background-color: rgb(0, 0, 0,0.4);
    width: 95%;
    margin-top: 50px;
}
.ack{
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-content: center;
}
